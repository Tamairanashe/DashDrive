// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "finance", "insurance", "billing", "marketing", "integration", "analytics", "fintech", "events", "marketplace", "mobility", "admin", "logistics"]
}

// ==========================================
// 1. CORE SCHEMA
// ==========================================

enum AppMode {
  CUSTOMER
  DRIVER

  @@schema("core")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  phone         String?
  password_hash String
  status        String    @default("active")
  active_mode   AppMode   @default(CUSTOMER)
  is_driver     Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  address       String?
  latitude      Float?
  longitude     Float?

  roles         UserRole[]
  borrower      Borrower?
  bnpl_account  BnplAccount?
  policies      Policy[]
  claims        Claim[]
  wallet        Wallet?
  students      Student[]
  reservations  Reservation[]
  hotel_bookings HotelBooking[]
  
  // Driver specific
  driver_profile DriverProfile?

  // Marketplace relations
  listings      Listing[]    @relation("HostListings")
  bookings      Booking[]    @relation("GuestBookings")
  messages_sent Message[]    @relation("SenderMessages")
  messages_received Message[] @relation("ReceiverMessages")
  wishlists     Wishlist[]
  reviews       Review[]     @relation("Reviewer")
  marketplaceOrders MarketplaceOrder[]
  fuelOrders    FuelOrder[]
  notifications AppNotification[]

  @@schema("core")
}

model DriverProfile {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @unique @db.Uuid
  license_number    String?
  vehicle_type      String?
  verification_status String @default("pending") // pending, verified, rejected
  is_online         Boolean  @default(false)
  last_location_lat Float?
  last_location_lng Float?
  rating            Float    @default(5.0)
  
  user              User     @relation(fields: [user_id], references: [id])
  driverWallet      DriverWallet?
  bundlePurchases   DriverBundlePurchase[]

  @@schema("core")
}

model Student {
  id           String   @id @default(uuid()) @db.Uuid
  parent_id    String   @db.Uuid
  name         String
  age          Int
  school_id    String   @db.Uuid
  grade        String?
  special_notes String?
  
  parent       User     @relation(fields: [parent_id], references: [id])
  school       School   @relation(fields: [school_id], references: [id])
  
  @@schema("core")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String
  latitude  Float
  longitude Float
  phone     String?
  
  students  Student[]
  
  @@schema("core")
}

model AppNotification {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  title       String
  message     String
  type        String   // push, sms, email
  metadata    Json     @default("{}")
  status      String   @default("sent") // sent, read, failed
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id])

  @@schema("core")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  role_name   String   @unique
  description String?
  
  users       UserRole[]
  permissions RolePermission[]

  @@schema("core")
}

model UserRole {
  user_id String @db.Uuid
  role_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id])
  role    Role   @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
  @@schema("core")
}

model Permission {
  id              String   @id @default(uuid()) @db.Uuid
  permission_name String   @unique
  
  roles           RolePermission[]

  @@schema("core")
}

model RolePermission {
  role_id       String @db.Uuid
  permission_id String @db.Uuid
  role          Role   @relation(fields: [role_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@schema("core")
}

model Organization {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  type       String   // financier_partner, insurance_partner, dashdrive_admin
  created_at DateTime @default(now())

  @@schema("core")
}

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  owner_id    String   @db.Uuid
  type        String   // loan_agreement, insurance_policy, etc.
  file_url    String
  uploaded_at DateTime @default(now())

  @@schema("core")
}

// ==========================================
// 2. FINANCE SCHEMA
// ==========================================

model LoanProduct {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  type          String
  min_amount    Decimal
  max_amount    Decimal
  min_term      Int
  max_term      Int
  interest_type String
  apr_min       Decimal
  apr_max       Decimal

  applications  Application[]

  @@schema("finance")
}

model Lead {
  id            String   @id @default(uuid()) @db.Uuid
  source        String
  external_id   String?
  first_name    String
  last_name     String
  email         String
  phone         String
  loan_amount   Decimal?
  status        String
  created_at    DateTime @default(now())

  @@schema("finance")
}

model Borrower {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @unique @db.Uuid
  first_name String
  last_name  String
  dob        DateTime
  ssn_last4  String?
  address    String?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id])
  applications Application[]

  @@schema("finance")
}

model Application {
  id               String   @id @default(uuid()) @db.Uuid
  borrower_id      String   @db.Uuid
  product_id       String   @db.Uuid
  requested_amount Decimal
  status           String   @default("submitted")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  borrower         Borrower @relation(fields: [borrower_id], references: [id])
  product          LoanProduct @relation(fields: [product_id], references: [id])
  underwriting     UnderwritingDecision?
  offers           LoanOffer[]
  loans            Loan[]

  @@schema("finance")
}

model UnderwritingDecision {
  id              String   @id @default(uuid()) @db.Uuid
  application_id  String   @unique @db.Uuid
  decision        String
  approved_amount Decimal?
  approved_term   Int?
  approved_apr    Decimal?
  notes           String?
  created_at      DateTime @default(now())

  application     Application @relation(fields: [application_id], references: [id])

  @@schema("finance")
}

model LoanOffer {
  id               String   @id @default(uuid()) @db.Uuid
  application_id   String   @db.Uuid
  lender_name      String
  amount           Decimal
  term             Int
  apr              Decimal
  monthly_payment  Decimal
  selected         Boolean  @default(false)

  application      Application @relation(fields: [application_id], references: [id])

  @@schema("finance")
}

model Loan {
  id             String   @id @default(uuid()) @db.Uuid
  application_id String   @db.Uuid
  lender_id      String   @db.Uuid
  amount         Decimal
  apr            Decimal
  term           Int
  status         String
  funded_at      DateTime?

  application    Application @relation(fields: [application_id], references: [id])
  repayments     Repayment[]

  @@schema("finance")
}

model Repayment {
  id             String   @id @default(uuid()) @db.Uuid
  loan_id        String   @db.Uuid
  amount         Decimal
  payment_source String   // trip_deduction, wallet, card, bank_transfer
  status         String
  payment_date   DateTime @default(now())

  loan           Loan     @relation(fields: [loan_id], references: [id])

  @@schema("finance")
}

// BNPL
model BnplAccount {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @unique @db.Uuid
  credit_limit     Decimal
  available_credit Decimal
  status           String   @default("active")

  user             User     @relation(fields: [user_id], references: [id])
  transactions     BnplTransaction[]

  @@schema("finance")
}

model BnplTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  account_id  String   @db.Uuid
  amount      Decimal
  merchant    String
  status      String   @default("active")
  created_at  DateTime @default(now())

  account     BnplAccount @relation(fields: [account_id], references: [id])
  repayments  BnplRepayment[]

  @@schema("finance")
}

model BnplRepayment {
  id             String   @id @default(uuid()) @db.Uuid
  transaction_id String   @db.Uuid
  amount         Decimal
  paid_at        DateTime @default(now())

  transaction    BnplTransaction @relation(fields: [transaction_id], references: [id])

  @@schema("finance")
}

// Vehicle Financing
model Vehicle {
  id    String @id @default(uuid()) @db.Uuid
  make  String
  model String
  year  Int
  price Decimal

  applications VehicleFinanceApplication[]

  @@schema("finance")
}

model VehicleFinanceApplication {
  id           String   @id @default(uuid()) @db.Uuid
  driver_id    String   @db.Uuid
  vehicle_id   String   @db.Uuid
  down_payment Decimal
  status       String   @default("pending")
  created_at   DateTime @default(now())

  vehicle      Vehicle  @relation(fields: [vehicle_id], references: [id])
  loan         VehicleLoan?

  @@schema("finance")
}

model VehicleLoan {
  id             String   @id @default(uuid()) @db.Uuid
  application_id String   @unique @db.Uuid
  amount         Decimal
  weekly_payment Decimal
  term_weeks     Int
  status         String

  application    VehicleFinanceApplication @relation(fields: [application_id], references: [id])

  @@schema("finance")
}

// ==========================================
// 3. INSURANCE SCHEMA
// ==========================================

model InsuranceProvider {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  api_endpoint String?
  status       String   @default("active")
  created_at   DateTime @default(now())

  products     InsuranceProduct[]

  @@schema("insurance")
}

model InsuranceProduct {
  id              String   @id @default(uuid()) @db.Uuid
  provider_id     String   @db.Uuid
  name            String
  coverage_amount Decimal
  premium         Decimal
  policy_type     String   // driver_accident, vehicle, trip, loan_protection

  provider        InsuranceProvider @relation(fields: [provider_id], references: [id])
  policies        Policy[]

  @@schema("insurance")
}

model Policy {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @db.Uuid
  product_id      String   @db.Uuid
  premium         Decimal
  coverage_amount Decimal
  status          String
  start_date      DateTime
  end_date        DateTime

  user            User     @relation(fields: [user_id], references: [id])
  product         InsuranceProduct @relation(fields: [product_id], references: [id])
  claims          Claim[]

  @@schema("insurance")
}

model Claim {
  id            String   @id @default(uuid()) @db.Uuid
  policy_id     String   @db.Uuid
  user_id       String   @db.Uuid
  incident_type String
  description   String?
  status        String   @default("submitted")
  amount_claimed Decimal? @db.Decimal(10, 2)
  created_at    DateTime @default(now())

  policy        Policy   @relation(fields: [policy_id], references: [id])
  user          User     @relation(fields: [user_id], references: [id])
  attachments   ClaimAttachment[]
  incident_report IncidentReport?

  @@schema("insurance")
}

model ClaimAttachment {
  id        String @id @default(uuid()) @db.Uuid
  claim_id  String @db.Uuid
  url       String
  file_type String // image, pdf, etc.

  claim     Claim  @relation(fields: [claim_id], references: [id])

  @@schema("insurance")
}

model IncidentReport {
  id          String   @id @default(uuid()) @db.Uuid
  claim_id    String   @unique @db.Uuid
  location    String?
  incident_at DateTime
  narrative   String

  claim       Claim    @relation(fields: [claim_id], references: [id])

  @@schema("insurance")
}

// ==========================================
// 4. BILLING SCHEMA
// ==========================================

model Transaction {
  id             String   @id @default(uuid()) @db.Uuid
  reference_id   String?  @db.Uuid
  type           String   // loan_disbursement, loan_repayment, insurance_premium, commission
  amount         Decimal
  status         String
  created_at     DateTime @default(now())

  @@schema("billing")
}

model Commission {
  id              String   @id @default(uuid()) @db.Uuid
  partner_id      String   @db.Uuid
  application_id  String   @db.Uuid
  amount          Decimal
  status          String
  due_date        DateTime
  paid_at         DateTime?

  @@schema("billing")
}

model Payout {
  id           String   @id @default(uuid()) @db.Uuid
  partner_id   String   @db.Uuid
  amount       Decimal
  status       String
  created_at   DateTime @default(now())

  @@schema("billing")
}

// ==========================================
// 5. MARKETING SCHEMA
// ==========================================

model Campaign {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  start_date DateTime
  end_date   DateTime
  status     String

  @@schema("marketing")
}

// ==========================================
// 6. INTEGRATION SCHEMA
// ==========================================

model Integration {
  id     String @id @default(uuid()) @db.Uuid
  name   String
  type   String
  config Json
  status String

  @@schema("integration")
}

// ==========================================
// 7. ANALYTICS SCHEMA & EVENTS
// ==========================================

// ==========================================
// 8. FINTECH SCHEMA (DashWallet & Payments)
// ==========================================

model Wallet {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @unique @db.Uuid
  balance       Decimal   @default(0.00)
  currency      String    @default("USD")
  status        String    @default("active") // active, frozen, closed
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user          User      @relation(fields: [user_id], references: [id])
  transactions  WalletTransaction[]

  @@schema("fintech")
}

model WalletTransaction {
  id            String    @id @default(uuid()) @db.Uuid
  wallet_id     String    @db.Uuid
  type          String    // credit, debit, transfer, payment, refund, withdrawal
  amount        Decimal
  status        String    @default("completed") // pending, completed, failed
  reference     String?   @unique
  description   String?
  created_at    DateTime  @default(now())

  wallet        Wallet    @relation(fields: [wallet_id], references: [id])

  @@schema("fintech")
}

model Transfer {
  id            String    @id @default(uuid()) @db.Uuid
  sender_id     String    @db.Uuid
  receiver_id   String    @db.Uuid
  amount        Decimal
  status        String    @default("completed")
  reference     String    @unique
  created_at    DateTime  @default(now())

  @@schema("fintech")
}

model Merchant {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  business_type String
  location      String?
  status        String    @default("active")
  created_at    DateTime  @default(now())

  payments      MerchantPayment[]

  @@schema("fintech")
}

model MerchantPayment {
  id             String    @id @default(uuid()) @db.Uuid
  merchant_id    String    @db.Uuid
  user_id        String    @db.Uuid
  amount         Decimal
  payment_method String    @default("wallet")
  status         String    @default("completed")
  created_at     DateTime  @default(now())

  merchant       Merchant  @relation(fields: [merchant_id], references: [id])

  @@schema("fintech")
}

model BillPayment {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String    @db.Uuid
  provider       String
  account_number String
  amount         Decimal
  status         String    @default("completed")
  created_at     DateTime  @default(now())

  @@schema("fintech")
}

model KYCRecord {
  id                  String    @id @default(uuid()) @db.Uuid
  user_id             String    @db.Uuid
  document_type       String    // passport, national_id, driver_license
  document_number     String
  verification_status String    @default("pending") // pending, verified, rejected
  created_at          DateTime  @default(now())

  @@schema("fintech")
}

model FintechLoan {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String    @db.Uuid
  amount         Decimal
  interest_rate  Decimal
  status         String    @default("active")
  due_date       DateTime
  created_at     DateTime  @default(now())

  @@schema("fintech")
}

// ==========================================
// 9. EVENTS SCHEMA
// ==========================================

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  venue_id    String?  @db.Uuid
  start_time  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  seats       Seat[]
  reservations Reservation[]

  @@schema("events")
}

model Seat {
  id          String   @id @default(uuid()) @db.Uuid
  event_id    String   @db.Uuid
  section     String
  row         String
  number      String
  status      String   @default("available") // available, locked, sold
  price       Decimal  @db.Decimal(10, 2)

  event       Event    @relation(fields: [event_id], references: [id])
  reservations Reservation[]
  tickets     Ticket[]

  @@schema("events")
}

model Reservation {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  event_id    String   @db.Uuid
  seat_id     String   @db.Uuid
  expires_at  DateTime
  status      String   @default("pending") // pending, completed, expired
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id])
  event       Event    @relation(fields: [event_id], references: [id])
  seat        Seat     @relation(fields: [seat_id], references: [id])
  ticket      Ticket?

  @@schema("events")
}

model Ticket {
  id             String   @id @default(uuid()) @db.Uuid
  reservation_id String   @unique @db.Uuid
  seat_id        String   @db.Uuid
  qr_code        String   @unique
  created_at     DateTime @default(now())

  reservation    Reservation @relation(fields: [reservation_id], references: [id])
  seat           Seat        @relation(fields: [seat_id], references: [id])

  @@schema("events")
}

// ==========================================
// 10. MARKETPLACE SCHEMA
// ==========================================

model Listing {
  id              String    @id @default(uuid()) @db.Uuid
  host_id         String    @db.Uuid
  title           String
  description     String?
  property_type   String    // apartment, house, car, boat, etc.
  price_per_night Decimal   @db.Decimal(10, 2)
  cleaning_fee    Decimal?  @db.Decimal(10, 2)
  max_guests      Int?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  host            User      @relation("HostListings", fields: [host_id], references: [id])
  location        Location?
  photos          ListingPhoto[]
  amenities       ListingAmenity[]
  bookings        Booking[]
  messages        Message[]
  wishlist_items  WishlistListing[]

  @@schema("marketplace")
}

model Location {
  id         String   @id @default(uuid()) @db.Uuid
  listing_id String   @unique @db.Uuid
  country    String
  city       String
  address    String
  latitude   Float
  longitude  Float

  listing    Listing  @relation(fields: [listing_id], references: [id])

  @@schema("marketplace")
}

model ListingPhoto {
  id         String   @id @default(uuid()) @db.Uuid
  listing_id String   @db.Uuid
  url        String
  caption    String?
  sort_order Int      @default(0)

  listing    Listing  @relation(fields: [listing_id], references: [id])

  @@schema("marketplace")
}

model Amenity {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique

  listings ListingAmenity[]

  @@schema("marketplace")
}

model ListingAmenity {
  listing_id String @db.Uuid
  amenity_id String @db.Uuid

  listing    Listing @relation(fields: [listing_id], references: [id])
  amenity    Amenity @relation(fields: [amenity_id], references: [id])

  @@id([listing_id, amenity_id])
  @@schema("marketplace")
}

model Booking {
  id           String    @id @default(uuid()) @db.Uuid
  listing_id   String    @db.Uuid
  guest_id     String    @db.Uuid
  check_in     DateTime
  check_out    DateTime
  total_price  Decimal   @db.Decimal(10, 2)
  status       String    @default("pending") // pending, confirmed, cancelled, completed
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  listing      Listing   @relation(fields: [listing_id], references: [id])
  guest        User      @relation("GuestBookings", fields: [guest_id], references: [id])
  payment      MarketplacePayment?
  review       Review?

  @@schema("marketplace")
}

model MarketplacePayment {
  id             String    @id @default(uuid()) @db.Uuid
  booking_id     String    @unique @db.Uuid
  amount         Decimal   @db.Decimal(10, 2)
  status         String    @default("pending")
  payment_method String
  created_at     DateTime  @default(now())

  booking        Booking   @relation(fields: [booking_id], references: [id])

  @@schema("marketplace")
}

model Message {
  id           String    @id @default(uuid()) @db.Uuid
  sender_id    String    @db.Uuid
  receiver_id  String    @db.Uuid
  listing_id   String?   @db.Uuid
  message_text String
  sent_at      DateTime  @default(now())

  sender       User      @relation("SenderMessages", fields: [sender_id], references: [id])
  receiver     User      @relation("ReceiverMessages", fields: [receiver_id], references: [id])
  listing      Listing?  @relation(fields: [listing_id], references: [id])

  @@schema("marketplace")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  booking_id  String   @unique @db.Uuid
  reviewer_id String   @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  booking     Booking  @relation(fields: [booking_id], references: [id])
  reviewer    User     @relation("Reviewer", fields: [reviewer_id], references: [id])

  @@schema("marketplace")
}

model Wishlist {
  id      String @id @default(uuid()) @db.Uuid
  user_id String @db.Uuid
  name    String

  user    User @relation(fields: [user_id], references: [id])
  items   WishlistListing[]

  @@schema("marketplace")
}

model WishlistListing {
  wishlist_id String @db.Uuid
  listing_id  String @db.Uuid

  wishlist    Wishlist @relation(fields: [wishlist_id], references: [id])
  listing     Listing  @relation(fields: [listing_id], references: [id])

  @@id([wishlist_id, listing_id])
  @@schema("marketplace")
}

model MarketplaceStore {
  id          String   @id @default(uuid()) @db.Uuid
  merchantId  String?  @db.Uuid
  name        String
  description String?
  imageUrl    String?
  category    String   // FOOD, MART, RETAIL
  rating      Float    @default(5.0)
  address     String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  categories  MarketplaceCategory[]
  products    MarketplaceProduct[]
  orders      MarketplaceOrder[]

  @@schema("marketplace")
}

model MarketplaceCategory {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @db.Uuid
  name    String

  store    MarketplaceStore     @relation(fields: [storeId], references: [id])
  products MarketplaceProduct[]

  @@schema("marketplace")
}

model MarketplaceProduct {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     String   @db.Uuid
  categoryId  String?  @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  store      MarketplaceStore     @relation(fields: [storeId], references: [id])
  category   MarketplaceCategory? @relation(fields: [categoryId], references: [id])
  orderItems MarketplaceOrderItem[]

  @@schema("marketplace")
}

model MarketplaceOrder {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  storeId      String   @db.Uuid
  totalAmount  Decimal  @db.Decimal(10, 2)
  status       String   @default("pending") // pending, paid, preparing, out_for_delivery, completed, cancelled
  instructions String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id])
  store  MarketplaceStore @relation(fields: [storeId], references: [id])
  items  MarketplaceOrderItem[]

  @@schema("marketplace")
}

model MarketplaceOrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)

  order   MarketplaceOrder   @relation(fields: [orderId], references: [id])
  product MarketplaceProduct @relation(fields: [productId], references: [id])

  @@schema("marketplace")
}

model Hotel {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  city        String
  address     String?
  latitude    Float?
  longitude   Float?
  starRating  Int?
  imageUrl    String?
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  roomTypes   HotelRoomType[]

  @@schema("marketplace")
}

model HotelRoomType {
  id             String   @id @default(uuid()) @db.Uuid
  hotelId        String   @db.Uuid
  name           String
  description    String?
  maxGuests      Int
  bedType        String?
  pricePerNight  Decimal  @db.Decimal(10, 2)
  totalInventory Int
  isActive       Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  hotel          Hotel    @relation(fields: [hotelId], references: [id])
  bookings       HotelBooking[]

  @@schema("marketplace")
}

model HotelBooking {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  roomTypeId    String   @db.Uuid
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  totalPrice    Decimal  @db.Decimal(10, 2)
  status        String   @default("confirmed") // confirmed, cancelled, completed
  paymentStatus String   @default("paid")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  roomType      HotelRoomType @relation(fields: [roomTypeId], references: [id])

  @@schema("marketplace")
}

// ==========================================
// 11. MOBILITY SCHEMA (Ride-Sharing)
// ==========================================

enum RideStatus {
  REQUESTED
  SEARCHING
  DRIVER_ASSIGNED
  DRIVER_ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_DRIVERS

  @@schema("mobility")
}

model RideServiceType {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @unique // economy, comfort, premium, xl, moto
  description   String?
  basePrice     Float
  pricePerKm    Float
  pricePerMin   Float
  maxPassengers Int       @default(4)
  iconUrl       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  rides         RideRequest[]

  @@schema("mobility")
}

model RideRequest {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  serviceTypeId     String      @db.Uuid
  pickupLat         Float
  pickupLng         Float
  pickupAddress     String
  dropoffLat        Float
  dropoffLng        Float
  dropoffAddress    String
  estimatedDistance Float?      // km
  estimatedDuration Int?        // minutes
  estimatedFare     Float?
  surgeMultiplier   Float       @default(1.0)
  status            RideStatus  @default(REQUESTED)
  scheduledAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  serviceType       RideServiceType @relation(fields: [serviceTypeId], references: [id])
  trip              RideTrip?

  @@schema("mobility")
}

model RideTrip {
  id            String    @id @default(uuid()) @db.Uuid
  rideRequestId String    @unique @db.Uuid
  driverId      String    @db.Uuid
  vehicleId     String?   @db.Uuid
  startedAt     DateTime?
  completedAt   DateTime?
  actualDistance Float?
  actualDuration Int?
  baseFare      Float?
  distanceFare  Float?
  timeFare      Float?
  surgeFare     Float?
  tollsFare     Float?
  totalFare     Float?
  paymentMethod String    @default("wallet")
  paymentStatus String    @default("pending")
  rating        Float?
  createdAt     DateTime  @default(now())

  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])

  @@schema("mobility")
}

// ==========================================
// 12. TRANSIT SCHEMA (Public Transport)
// ==========================================

enum TransitType {
  BUS
  TRAIN
  METRO
  FERRY
  MINIBUS

  @@schema("mobility")
}

enum TransitPassType {
  DAILY
  WEEKLY
  MONTHLY
  STUDENT

  @@schema("mobility")
}

model TransitRoute {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  routeNumber String      @unique
  type        TransitType @default(BUS)
  baseFare    Float       @default(1.0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  stops       RouteStop[]
  trips       TransitTrip[]

  @@schema("mobility")
}

model TransitStop {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  routes    RouteStop[]
  boardingTrips TransitTrip[] @relation("BoardStop")
  alightingTrips TransitTrip[] @relation("AlightStop")

  @@schema("mobility")
}

model RouteStop {
  routeId   String @db.Uuid
  stopId    String @db.Uuid
  stopOrder Int

  route     TransitRoute @relation(fields: [routeId], references: [id])
  stop      TransitStop  @relation(fields: [stopId], references: [id])

  @@id([routeId, stopId])
  @@schema("mobility")
}

model TransitPass {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  type       TransitPassType
  validFrom  DateTime        @default(now())
  validUntil DateTime
  qrCode     String          @unique
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())

  trips      TransitTrip[]
  productId  String?         @db.Uuid
  product    TransitProduct? @relation(fields: [productId], references: [id])

  @@schema("mobility")
}

model TransitProduct {
  id          String          @id @default(uuid()) @db.Uuid
  type        TransitPassType
  name        String
  price       Decimal         @db.Decimal(10, 2)
  durationDays Int
  isActive    Boolean         @default(true)
  created_at  DateTime        @default(now())

  passes      TransitPass[]

  @@schema("mobility")
}

model TransitTrip {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  routeId      String   @db.Uuid
  boardStopId  String   @db.Uuid
  alightStopId String?  @db.Uuid
  passId       String?  @db.Uuid
  fare         Float    @default(0)
  createdAt    DateTime @default(now())

  route        TransitRoute @relation(fields: [routeId], references: [id])
  boardStop    TransitStop  @relation("BoardStop", fields: [boardStopId], references: [id])
  alightStop   TransitStop? @relation("AlightStop", fields: [alightStopId], references: [id])
  pass         TransitPass? @relation(fields: [passId], references: [id])

  @@schema("mobility")
}

// ==========================================
// 13. FUEL SCHEMA
// ==========================================

model FuelStation {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  address     String
  latitude    Float
  longitude   Float
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())

  fuelTypes   FuelType[]
  orders      FuelOrder[]

  @@schema("mobility")
}

model FuelType {
  id           String      @id @default(uuid()) @db.Uuid
  stationId    String      @db.Uuid
  name         String      // Petrol 93, Diesel, etc.
  pricePerUnit Decimal     @db.Decimal(10, 2)
  unit         String      @default("litre")
  isAvailable  Boolean     @default(true)

  station      FuelStation @relation(fields: [stationId], references: [id])
  orders       FuelOrder[]

  @@schema("mobility")
}

model FuelOrder {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  stationId     String      @db.Uuid
  fuelTypeId    String      @db.Uuid
  quantity      Decimal     @db.Decimal(10, 2)
  totalPrice    Decimal     @db.Decimal(10, 2)
  orderType     String      // self, delivery
  status        String      @default("confirmed")
  created_at    DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id])
  station       FuelStation @relation(fields: [stationId], references: [id])
  fuelType      FuelType    @relation(fields: [fuelTypeId], references: [id])

  @@schema("mobility")
}

// ==========================================
// 14. DRIVER PREPAID WALLET & RIDE BUNDLES
// ==========================================

model DriverWallet {
  id              String   @id @default(uuid()) @db.Uuid
  driverProfileId String   @unique @db.Uuid
  balance         Decimal  @default(0) @db.Decimal(10, 2)
  currency        String   @default("USD")
  status          String   @default("active")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
  transactions    DriverWalletTransaction[]

  @@schema("mobility")
}

model DriverWalletTransaction {
  id              String   @id @default(uuid()) @db.Uuid
  walletId        String   @db.Uuid
  type            String   // topup, bundle_purchase, refund
  amount          Decimal  @db.Decimal(10, 2)
  description     String?
  reference       String?
  status          String   @default("completed")
  created_at      DateTime @default(now())

  wallet          DriverWallet @relation(fields: [walletId], references: [id])

  @@schema("mobility")
}

model RideBundle {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   // "Starter 20", "Pro 50", "Elite 100"
  rideCount     Int      // Number of ride credits
  price         Decimal  @db.Decimal(10, 2)
  validityDays  Int      @default(30)
  isActive      Boolean  @default(true)
  created_at    DateTime @default(now())

  purchases     DriverBundlePurchase[]

  @@schema("mobility")
}

model DriverBundlePurchase {
  id              String   @id @default(uuid()) @db.Uuid
  driverProfileId String   @db.Uuid
  bundleId        String   @db.Uuid
  ridesRemaining  Int
  ridesUsed       Int      @default(0)
  validUntil      DateTime
  status          String   @default("active") // active, expired, exhausted
  created_at      DateTime @default(now())

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
  bundle          RideBundle    @relation(fields: [bundleId], references: [id])

  @@schema("mobility")
}
