generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  FOOD
  MART
  SHOPPING
}

model Category {
  id         String    @id
  storeId    String
  merchantId String
  name       String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  Store      Store     @relation(fields: [storeId], references: [id])
  Product    Product[]
}

model Country {
  id        String     @id
  name      String
  code      String     @unique
  currency  String
  timezone  String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  Merchant  Merchant[]
}

model Coupon {
  id                String       @id
  storeId           String
  merchantId        String
  code              String       @unique
  discountType      DiscountType @default(PERCENTAGE)
  discountValue     Float
  minOrderAmount    Float        @default(0)
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int          @default(0)
  startDate         DateTime
  endDate           DateTime
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  Campaign          Campaign?    @relation(fields: [campaignId], references: [id])
  campaignId        String?
  Store             Store        @relation(fields: [storeId], references: [id])
}

model Campaign {
  id          String   @id @default(uuid())
  merchantId  String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  promotions Promotion[]
  coupons    Coupon[]
  merchant   Merchant    @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

model Delivery {
  id          String         @id
  orderId     String         @unique
  riderId     String?
  status      DeliveryStatus @default(PENDING)
  pickupTime  DateTime?
  deliveredAt DateTime?
  distanceKm  Float?
  deliveryFee Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime
  Order       Order          @relation(fields: [orderId], references: [id])
  Rider       Rider?         @relation(fields: [riderId], references: [id])
}

model DeliveryOffer {
  id          String      @id
  orderId     String      @unique
  proposedFee Float
  currency    String
  expiresAt   DateTime
  status      OfferStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  Order       Order       @relation(fields: [orderId], references: [id])
  RiderBid    RiderBid[]
}

model FeaturedItem {
  id         String   @id
  storeId    String
  merchantId String
  productId  String
  boostLevel Float    @default(1.5)
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  Product    Product  @relation(fields: [productId], references: [id])
  Store      Store    @relation(fields: [storeId], references: [id])
}

model InventoryLog {
  id         String   @id
  productId  String
  variantId  String?
  change     Int
  reason     String
  merchantId String
  createdAt  DateTime @default(now())
}

model LedgerEntry {
  id          String     @id
  walletId    String
  amount      Float
  type        LedgerType
  referenceId String?
  description String?
  createdAt   DateTime   @default(now())
  Wallet      Wallet     @relation(fields: [walletId], references: [id])
}

model Merchant {
  id           String       @id
  countryId    String
  email        String       @unique
  passwordHash String
  storeName    String
  type         BusinessType @default(MART)
  phone        String?
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  Country      Country      @relation(fields: [countryId], references: [id])
  Store        Store[]
  Campaign     Campaign[]
}

model Modifier {
  id              String        @id
  modifierGroupId String
  name            String
  price           Float         @default(0)
  stock           Int?
  createdAt       DateTime      @default(now())
  ModifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])
}

model ModifierGroup {
  id        String     @id
  productId String
  name      String
  minSelect Int        @default(0)
  maxSelect Int        @default(1)
  createdAt DateTime   @default(now())
  Modifier  Modifier[]
  Product   Product    @relation(fields: [productId], references: [id])
}

model Order {
  id              String      @id
  storeId         String
  merchantId      String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  currency        String
  subtotal        Float
  taxAmount       Float       @default(0)
  deliveryFee     Float       @default(0)
  totalAmount     Float
  customerName    String?
  customerPhone   String?
  deliveryAddress String?

  // Marketing & Discounts
  couponId       String?
  discountAmount Float   @default(0)

  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Delivery           Delivery?
  DeliveryOffer      DeliveryOffer?
  Store              Store                @relation(fields: [storeId], references: [id])
  OrderItem          OrderItem[]
  OrderStatusHistory OrderStatusHistory[]
  Transaction        Transaction[]

  @@index([createdAt])
  @@index([merchantId])
  @@index([status])
  @@index([storeId])
}

model OrderItem {
  id         String @id
  orderId    String
  productId  String
  name       String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  Order      Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id        String      @id
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  Order     Order       @relation(fields: [orderId], references: [id])
}

model Product {
  id                String   @id
  storeId           String
  merchantId        String
  categoryId        String?
  name              String
  description       String?
  basePrice         Float
  sku               String?  @unique
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  images            String[]
  isActive          Boolean  @default(true)

  // Vertical-specific attributes
  barcode      String? @unique
  weightUnit   String?
  isHalal      Boolean @default(false)
  isVegan      Boolean @default(false)
  isVegetarian Boolean @default(false)
  attributes   Json?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  FeaturedItem   FeaturedItem[]
  ModifierGroup  ModifierGroup[]
  Category       Category?        @relation(fields: [categoryId], references: [id])
  Store          Store            @relation(fields: [storeId], references: [id])
  ProductVariant ProductVariant[]
}

model ProductVariant {
  id        String   @id
  productId String
  name      String
  sku       String?  @unique
  price     Float?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id])
}

model Promotion {
  id          String    @id
  storeId     String
  merchantId  String
  name        String
  description String?
  bannerImage String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  Campaign    Campaign? @relation(fields: [campaignId], references: [id])
  campaignId  String?
  Store       Store     @relation(fields: [storeId], references: [id])
}

model Rider {
  id              String     @id
  name            String
  phone           String     @unique
  email           String?
  vehicleType     String     @default("BICYCLE")
  licensePlate    String?
  isOnline        Boolean    @default(false)
  isActive        Boolean    @default(true)
  countryCode     String
  latitude        Float?
  longitude       Float?
  rating          Float      @default(5.0)
  totalDeliveries Int        @default(0)
  currentLoad     Int        @default(0)
  createdAt       DateTime   @default(now())
  Delivery        Delivery[]
  RiderBid        RiderBid[]
}

model RiderBid {
  id            String        @id
  offerId       String
  riderId       String
  bidAmount     Float
  createdAt     DateTime      @default(now())
  DeliveryOffer DeliveryOffer @relation(fields: [offerId], references: [id])
  Rider         Rider         @relation(fields: [riderId], references: [id])
}

model RiskEvent {
  id          String        @id
  eventType   RiskEventType
  referenceId String
  actorId     String
  actorType   RiskActorType
  riskScore   Float
  decision    RiskDecision
  reasons     Json?
  createdAt   DateTime      @default(now())
}

model Store {
  id             String  @id
  merchantId     String
  name           String
  address        String
  city           String
  currency       String
  timezone       String
  taxRate        Float   @default(0)
  commissionRate Float   @default(0.10)
  isActive       Boolean @default(true)

  // Vertical-specific attributes
  rating            Float    @default(0)
  reviewCount       Int      @default(0)
  estimatedPrepTime Int      @default(20)
  cuisineTypes      String[] @default([])
  isPromoted        Boolean  @default(false)

  createdAt    DateTime       @default(now())
  Category     Category[]
  Coupon       Coupon[]
  FeaturedItem FeaturedItem[]
  Order        Order[]
  Product      Product[]
  Promotion    Promotion[]
  Merchant     Merchant       @relation(fields: [merchantId], references: [id])
  Review       Review[]
}

model Review {
  id         String   @id
  storeId    String
  customerId String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  Store      Store    @relation(fields: [storeId], references: [id])
}

model Transaction {
  id                   String        @id
  orderId              String
  storeId              String
  merchantId           String
  gateway              String
  gatewayTransactionId String?
  currency             String
  amount               Float
  status               PaymentStatus @default(PENDING)
  paymentMethod        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime
  Order                Order         @relation(fields: [orderId], references: [id])
}

model Wallet {
  id                String              @id
  ownerType         WalletOwnerType
  ownerId           String
  currency          String
  balance           Float               @default(0)
  isFrozen          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  LedgerEntry       LedgerEntry[]
  WithdrawalRequest WithdrawalRequest[]

  @@unique([ownerType, ownerId, currency])
}

model WithdrawalRequest {
  id        String           @id
  walletId  String
  amount    Float
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())
  Wallet    Wallet           @relation(fields: [walletId], references: [id])
}

model Zone {
  id              String   @id
  name            String
  countryCode     String
  minLat          Float
  maxLat          Float
  minLng          Float
  maxLng          Float
  surgeMultiplier Float    @default(1.0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum OfferStatus {
  OPEN
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  ASSIGNED_TO_RIDER
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum RiskActorType {
  CUSTOMER
  MERCHANT
  RIDER
}

enum RiskDecision {
  APPROVED
  REVIEW
  BLOCKED
}

enum RiskEventType {
  ORDER
  PAYMENT
  WITHDRAWAL
  DELIVERY
  WALLET
}

enum WalletOwnerType {
  CUSTOMER
  MERCHANT
  RIDER
  PLATFORM
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum AdminRole {
  SUPER_ADMIN
  FLEET_MANAGER
  SUPPORT_AGENT
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(SUPPORT_AGENT)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  auditLogs AdminAuditEntry[]
}

model AdminGlobalConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model AdminAuditEntry {
  id        String    @id @default(cuid())
  adminId   String
  action    String
  resource  String
  payload   Json?
  ipAddress String?
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id])
}

model AdminSystemLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  message   String
  context   String?
  metadata  Json?
  createdAt DateTime @default(now())
}

// Fintech Distribution Platform Models

enum FintechProductType {
  LOAN
  INSURANCE
  CREDIT
  INVESTMENT
}

enum FintechStatus {
  LEAD_CREATED
  APPLICATION_STARTED
  APPLICATION_COMPLETED
  CONDITIONALLY_APPROVED
  APPROVED
  FUNDED
  CONVERTED
  DECLINED
  CANCELLED
  INVALIDATED
  REVERSED
}

model FintechLead {
  id             String             @id @default(uuid())
  leadUuid       String             @unique // External UUID from partner
  userId         String
  userType       String             // Driver, Customer
  productType    FintechProductType
  provider       String
  offerId        String?
  initialAmount  Float?
  apr            Float?
  status         FintechStatus      @default(LEAD_CREATED)
  metadata       Json?              // Additional criteria used for the lead
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  applications   FintechApplication[]
  payouts        FintechPayout[]

  @@index([userId])
  @@index([leadUuid])
  @@index([status])
}

model FintechApplication {
  id             String        @id @default(uuid())
  leadId         String
  externalAppId  String?       @unique
  status         FintechStatus @default(APPLICATION_STARTED)
  currentStep    String?
  lastUpdate     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead           FintechLead   @relation(fields: [leadId], references: [id])

  @@index([leadId])
}

model FintechPayout {
  id             String        @id @default(uuid())
  transactionId  String        @unique // external transaction id
  leadId         String
  amount         Float
  currency       String        @default("USD")
  eventType      String        // funded, conversion, etc.
  status         FintechStatus @default(CONVERTED)
  processedAt    DateTime      @default(now())
  metadata       Json?

  lead           FintechLead   @relation(fields: [leadId], references: [id])
  commission     FintechCommission?

  @@index([leadId])
  @@index([transactionId])
}

model FintechCommission {
  id               String   @id @default(uuid())
  payoutId         String   @unique
  provider         String
  billingCycle     String?  // e.g. "2026-03"
  commissionAmount Float
  status           String   @default("PENDING") // PENDING, INVOICED, PAID, REVERSED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payout           FintechPayout @relation(fields: [payoutId], references: [id])

  @@index([provider])
}
